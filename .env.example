# Alpaca — free account at https://alpaca.markets (paper account is fine).
# Used only for the realtime news websocket; no trading happens.
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# Anthropic — headline classification. Key from https://platform.claude.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Telegram — create a bot via @BotFather, then get your chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates after messaging the bot once.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sources
ENABLE_NEWS=true
ENABLE_FILINGS=true
ENABLE_HALTS=true
ENABLE_OPTIONS=false

# SEC EDGAR — the SEC requires a real contact email in the User-Agent.
SEC_USER_AGENT=candlechaser/1.0 you@example.com
EDGAR_POLL_SECONDS=10
HALTS_POLL_SECONDS=5
CLUSTER_BUY_WINDOW_DAYS=5
CLUSTER_BUY_MIN_INSIDERS=2

# Options flow (Phase 4, not built yet)
POLYGON_API_KEY=

# Behavior
ALERT_SCORE_THRESHOLD=70
TICKER_COOLDOWN_MINUTES=15
MARKET_HOURS_ONLY=true
ALERT_START_ET=04:00
ALERT_END_ET=20:00
DB_PATH=./candlechaser.db
